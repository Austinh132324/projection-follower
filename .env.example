# Copy to .env and adjust. All paths are relative to the project root unless absolute.

# Where local data lives (SQLite DB + Playwright session state). Gitignored.
PF_DATA_DIR=./data

# API server port (the React dashboard talks to this).
PF_PORT=4000

# Run scrapers with a visible browser window. Interactive login always runs
# headed regardless; this only affects background sync/fetch runs.
PF_HEADLESS=true

# Comma-separated books to include in a full sync. Add fanduel,prizepicks
# as their modules come online.
PF_BOOKS=draftkings

# --- Per-book overrides (optional) -----------------------------------------
# Books redesign their sites. When DraftKings moves its bet-history endpoint,
# point the scraper at the new URL here instead of editing code. Leave blank
# to use the module's built-in default + auto-discovery fallback.
PF_DK_WAGERS_ENDPOINT=
